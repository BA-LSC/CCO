{
  "name": "@cco/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=../../.env next dev -p 3000",
    "build": "CCO_DEPLOY_TARGET=cloudflare NEXT_PUBLIC_DIRECT_UPLOADS=1 next build",
    "build:cloudflare": "CCO_DEPLOY_TARGET=cloudflare NEXT_PUBLIC_DIRECT_UPLOADS=1 opennextjs-cloudflare build",
    "preview:cloudflare": "CCO_DEPLOY_TARGET=cloudflare opennextjs-cloudflare preview",
    "deploy:cloudflare": "CCO_DEPLOY_TARGET=cloudflare opennextjs-cloudflare deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "generate:emoji-picker": "node scripts/generate-emoji-picker-data.mjs"
  },
  "dependencies": {
    "@cco/pco-client": "workspace:*",
    "@cco/shared": "workspace:*",
    "@cloudflare/realtimekit-react": "^1.5.1",
    "@cloudflare/realtimekit-react-ui": "^1.2.0",
    "heic2any": "^0.0.4",
    "ioredis": "^5.11.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "emojibase-data": "^17.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "typescript": "^6.0.3",
    "wrangler": "^4.95.0"
  }
}
