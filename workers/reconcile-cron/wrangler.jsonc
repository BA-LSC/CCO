  "compatibility_date": "2026-05-28",
  "triggers": {
    "crons": ["0 3 * * *", "*/10 * * * *"],
  },
  "vars": {
    // RECONCILE_INTERNAL_URL = https://api.example.com/internal/jobs/reconcile
