# Domains and TLS email are injected via environment variables (see docker-compose.prod.yml).
# WEB: https://chat.example.com
# API: https://api.chat.example.com

{
	email {$CADDY_EMAIL}
}

{$CCO_DOMAIN} {
	encode gzip
	reverse_proxy web:3000
}

{$API_DOMAIN} {
	encode gzip
	reverse_proxy api:3001
}
