# syntax=docker/dockerfile:1

FROM oven/bun:1.3.14-alpine AS base
WORKDIR /app

FROM base AS deps
COPY package.json bun.lock tsconfig.base.json ./
COPY apps/web/package.json apps/web/
COPY packages/pco-client/package.json packages/pco-client/
COPY packages/shared/package.json packages/shared/
COPY services/api/package.json services/api/
RUN --mount=type=cache,target=/root/.bun/install/cache,sharing=locked \
    bun install --frozen-lockfile --filter @cco/web

FROM base AS package-build
COPY package.json bun.lock tsconfig.base.json ./
COPY apps/web/package.json apps/web/
COPY packages/pco-client/package.json packages/pco-client/
COPY packages/shared/package.json packages/shared/
COPY services/api/package.json services/api/
COPY packages ./packages
COPY --from=deps /app/node_modules ./node_modules
# Install package devDependencies (typescript) omitted by --filter @cco/web.
RUN --mount=type=cache,target=/root/.bun/install/cache,sharing=locked \
    bun install --frozen-lockfile --filter @cco/shared --filter @cco/pco-client
RUN bun run --cwd packages/shared build && bun run --cwd packages/pco-client build

FROM node:26-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY package.json bun.lock tsconfig.base.json ./
COPY apps/web ./apps/web
COPY --from=package-build /app/packages ./packages
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules

ARG NEXT_PUBLIC_WS_URL
ARG NEXT_PUBLIC_WEB_URL
ARG CCO_BUILD_ID=dev
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_WS_URL=${NEXT_PUBLIC_WS_URL}
ENV NEXT_PUBLIC_WEB_URL=${NEXT_PUBLIC_WEB_URL}
ENV CCO_BUILD_ID=${CCO_BUILD_ID}

WORKDIR /app/apps/web
# Next.js static generation is more reliable under Node than Bun in Linux containers.
RUN --mount=type=cache,target=/app/apps/web/.next/cache,sharing=locked \
    node node_modules/next/dist/bin/next build \
 && node scripts/prepare-standalone.mjs

FROM base AS runner
ARG CCO_BUILD_ID=dev
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV CCO_BUILD_ID=${CCO_BUILD_ID}
WORKDIR /app

RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs

COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
# Static assets are copied into standalone by scripts/prepare-standalone.mjs during build.

USER nextjs
WORKDIR /app/apps/web
EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD bun -e "fetch('http://127.0.0.1:3000/').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["bun", "server.js"]
