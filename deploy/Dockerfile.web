# syntax=docker/dockerfile:1

FROM oven/bun:1.3-alpine AS base
WORKDIR /app

FROM base AS deps
COPY package.json bun.lock ./
COPY apps/web/package.json apps/web/
COPY apps/mobile/package.json apps/mobile/
COPY packages/pco-client/package.json packages/pco-client/
COPY packages/shared/package.json packages/shared/
COPY services/api/package.json services/api/
# Install web dependencies only so Expo/mobile does not pin React 18 at the repo root.
RUN bun install --frozen-lockfile --filter @cco/web

FROM node:26-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY package.json bun.lock ./
COPY apps/web ./apps/web
COPY packages ./packages

ARG NEXT_PUBLIC_WS_URL
ARG NEXT_PUBLIC_WEB_URL
ARG CCO_BUILD_ID=dev
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_WS_URL=${NEXT_PUBLIC_WS_URL}
ENV NEXT_PUBLIC_WEB_URL=${NEXT_PUBLIC_WEB_URL}
ENV CCO_BUILD_ID=${CCO_BUILD_ID}

WORKDIR /app/apps/web
# Next.js static generation is more reliable under Node than Bun in Linux containers.
RUN node node_modules/next/dist/bin/next build \
 && node scripts/prepare-standalone.mjs

FROM base AS runner
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
WORKDIR /app

RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs

COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
# Static assets are copied into standalone by scripts/prepare-standalone.mjs during build.

USER nextjs
WORKDIR /app/apps/web
EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD bun -e "fetch('http://127.0.0.1:3000/').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["bun", "server.js"]
