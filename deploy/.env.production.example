# Production environment — guided setup (recommended):
#
#   ./deploy/setup.sh
#
# Manual copy: cp deploy/.env.production.example .env — then edit or run setup.sh

# --- Public URLs (Cloudflare Tunnel hostnames) ---
CCO_DOMAIN=chat.example.com
API_DOMAIN=api.example.com
WEB_URL=https://chat.example.com
API_URL=http://api:3001
NEXT_PUBLIC_WS_URL=wss://api.example.com
NEXT_PUBLIC_WEB_URL=https://chat.example.com
PUBLIC_UPLOAD_URL=https://chat.example.com/api/v1/uploads

# --- Cloudflare Tunnel (https://one.dash.cloudflare.com/) ---
# Run token — created automatically by ./deploy/setup.sh (Cloudflare API).
CLOUDFLARE_TUNNEL_TOKEN=

# --- Planning Center OAuth (https://developer.planning.center/) ---
# Optional here — enter client ID and secret at https://<CCO_DOMAIN>/setup after deploy.
PCO_CLIENT_ID=
PCO_CLIENT_SECRET=
PCO_OAUTH_SCOPE="people groups services"
PCO_WEB_REDIRECT_URI=https://chat.example.com/api/auth/pco/callback
PCO_REDIRECT_URI=https://api.example.com/auth/pco/callback
PCO_MOBILE_REDIRECT_URI=https://api.example.com/auth/pco/mobile/callback
MOBILE_APP_SCHEME=connect
MOBILE_ORIGIN=

# --- Security (generate with: openssl rand -hex 32) ---
SESSION_SECRET=CHANGE_ME_32_CHAR_MINIMUM_SECRET_VALUE
TOKEN_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARACTERS_0123456789abcdef0123456789abcdef

# --- Database ---
# Default: PostgreSQL container on the same host (docker-compose.prod.yml).
POSTGRES_USER=cco
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=cco
DATABASE_URL=postgresql://cco:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/cco

# Optional: Vultr Managed PostgreSQL over VPC (see deploy/README.md).
# On the server: ./deploy/configure-vultr-db.sh
# Or set DATABASE_URL to the VPC host — bootstrap adds sslmode=require and skips bundled postgres.

# --- Redis (required for production realtime across restarts) ---
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379

# --- App ---
API_PORT=3001
# Web Push (required for home-screen / PWA message notifications).
# Generate with: cd services/api && bun -e "import w from 'web-push'; const k=w.generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY='+k.publicKey); console.log('VAPID_PRIVATE_KEY='+k.privateKey);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourchurch.org
# Webhook secret is configured during /setup (stored encrypted in DB).
PCO_ORGANIZATION_ID=
ORGANIZATION_NAME="My Church"
UPLOAD_DIR=/data/uploads

# Giphy GIF search — optional; set the API key in Admin → Integration settings, or override here:
# GIPHY_API_KEY=
