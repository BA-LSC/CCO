# Production environment — guided setup (recommended):
#
#   ./deploy/setup.sh
#
# Manual copy: cp deploy/.env.production.example .env — then edit or run setup.sh

# --- Public URLs (Cloudflare Tunnel hostnames) ---
CCO_DOMAIN=chat.example.com
API_DOMAIN=api.example.com
WEB_URL=https://chat.example.com
API_URL=http://api:3001
NEXT_PUBLIC_WS_URL=wss://api.example.com
NEXT_PUBLIC_WEB_URL=https://chat.example.com
PUBLIC_UPLOAD_URL=https://chat.example.com/api/v1/uploads

# --- Cloudflare Tunnel (https://one.dash.cloudflare.com/) ---
# Run token — created automatically by ./deploy/setup.sh (Cloudflare API).
CLOUDFLARE_TUNNEL_TOKEN=

# --- Planning Center OAuth (https://developer.planning.center/) ---
# Optional here — enter client ID and secret at https://<CCO_DOMAIN>/setup after deploy.
PCO_CLIENT_ID=
PCO_CLIENT_SECRET=
PCO_OAUTH_SCOPE="people groups services"
PCO_WEB_REDIRECT_URI=https://chat.example.com/api/auth/pco/callback
PCO_REDIRECT_URI=https://api.example.com/auth/pco/callback
PCO_MOBILE_REDIRECT_URI=https://api.example.com/auth/pco/mobile/callback
MOBILE_APP_SCHEME=connect
MOBILE_ORIGIN=

# --- Security (generate with: openssl rand -hex 32) ---
SESSION_SECRET=REPLACE_WITH_openssl_rand_hex_32
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_hex_32

# --- Database ---
# Default: PostgreSQL container on the same host (docker-compose.prod.yml).
POSTGRES_USER=cco
POSTGRES_PASSWORD=REPLACE_WITH_strong_password
POSTGRES_DB=cco
DATABASE_URL=postgresql://cco:REPLACE_WITH_strong_password@postgres:5432/cco

# Optional: Vultr Managed PostgreSQL over VPC (see deploy/README.md).
# On the server: ./deploy/configure-vultr-db.sh
# Or set DATABASE_URL to the VPC host — bootstrap adds sslmode=require and skips bundled postgres.

# --- Redis (required for production realtime across restarts) ---
REDIS_PASSWORD=REPLACE_WITH_strong_password
REDIS_URL=redis://:REPLACE_WITH_strong_password@redis:6379

# --- App ---
API_PORT=3001
# Web Push (required for home-screen / PWA message notifications).
# Generate with: cd services/api && bun -e "import w from 'web-push'; const k=w.generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY='+k.publicKey); console.log('VAPID_PRIVATE_KEY='+k.privateKey);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourchurch.org
# Webhook secret is configured during /setup (stored encrypted in DB).
PCO_ORGANIZATION_ID=
ORGANIZATION_NAME="My Church"
UPLOAD_DIR=/data/uploads

# Giphy GIF search — optional; set the API key in Admin → Integration settings, or override here:
# GIPHY_API_KEY=

# Cloudflare RealtimeKit (audio/video calls — media runs on Cloudflare edge, no VPS ports)
# In Admin → Integrations, paste a Realtime Admin API token; CCO resolves account/app automatically.
# Or override all values here for Docker/env-based config:
# CLOUDFLARE_ACCOUNT_ID=
# REALTIMEKIT_APP_ID=
# CLOUDFLARE_API_TOKEN=
# REALTIMEKIT_PRESET_HOST=host
# REALTIMEKIT_PRESET_MEMBER=group_call_participant
# REALTIMEKIT_PRESET_GUEST=guest

# --- Cloudflare platform (auto-provisioned via Integrations token; optional env overrides) ---
# R2 media uploads (Phase 1)
# CLOUDFLARE_R2_BUCKET=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_PUBLIC_URL=https://media.example.com
# UPLOAD_STORAGE=r2

# Workers internal auth (shared secret for VPS ↔ Worker callbacks)
# CF_INTERNAL_SECRET=

# Hyperdrive / Queues / KV (stored in DB after auto-provision; env fallback)
# CLOUDFLARE_HYPERDRIVE_ID=
# CLOUDFLARE_PUSH_QUEUE_ID=
# CLOUDFLARE_KV_PRESENCE_NAMESPACE_ID=
# CLOUDFLARE_KV_DEPLOY_NAMESPACE_ID=

# Replace Redis pub/sub with Durable Object fan-out (Phase 10)
# CF_REALTIME_FANOUT_URL=https://cco-realtime-fanout.<account>.workers.dev
# CF_REALTIME_INTERNAL_SECRET=

# Use KV instead of Redis for presence / deploy overlay (Phase 10)
# CF_PRESENCE_KV=1
# CF_DEPLOY_KV=1
# CF_PUSH_QUEUE_ENABLED=1

# --- Cloudflare Pages (OpenNext web) — see deploy/cloudflare/README.md ---
# CCO_DEPLOY_TARGET=cloudflare
# NEXT_PUBLIC_DIRECT_UPLOADS=1
# On Pages: set API_DOMAIN (not API_URL=http://api:3001)
# Build: bun run --cwd apps/web build:cloudflare
# Deploy: cd apps/web && npx wrangler deploy
