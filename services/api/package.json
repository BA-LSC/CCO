{
  "name": "@cco/api",
  "version": "0.0.1",
  "type": "module",
  "main": "src/app.ts",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "test": "SESSION_SECRET=test-secret-must-be-at-least-32-characters-long!! bun test",
