    "db:generate": "drizzle-kit generate",
    "jobs:reconcile": "bun run src/jobs/runner.ts"
  },
  "dependencies": {
    "@cco/pco-client": "workspace:*",
    "@cco/shared": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.21",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "postgres": "^3.4.9",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
