{
  "name": "cco",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=26"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/web", "apps/install", "packages/*", "services/*", "workers/*"],
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@cco/shared --filter=@cco/pco-client --filter=@cco/cloudflare-provision --filter=@cco/db",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "bun test packages services/api",
    "lint": "turbo run lint",
    "prepare": "bash scripts/install-git-hooks.sh",
    "audit": "bun audit",
    "audit:ci": "bun audit --audit-level=high"
  },
  "devDependencies": {
    "turbo": "^2.9.15",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "esbuild": "^0.25.12",
    "@esbuild-kit/core-utils/esbuild": "^0.25.12"
  }
}
