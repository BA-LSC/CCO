# Copy to the repository root: cp .env.example .env

DATABASE_URL=postgresql://connect:connect@localhost:5432/connect
REDIS_URL=redis://localhost:6379
# Production (deploy/setup.sh generates these):
# REDIS_PASSWORD=
# REDIS_URL=redis://:your-redis-password@redis:6379

# Planning Center OAuth — https://developer.planning.center/
PCO_CLIENT_ID=
PCO_CLIENT_SECRET=
PCO_OAUTH_SCOPE=people groups services
PCO_WEB_REDIRECT_URI=http://localhost:3000/auth/pco/callback
PCO_REDIRECT_URI=http://localhost:3001/auth/pco/callback
PCO_MOBILE_REDIRECT_URI=http://localhost:3001/auth/pco/mobile/callback
PCO_WEBHOOK_URL=http://localhost:3001/webhooks/pco
MOBILE_APP_SCHEME=connect
MOBILE_ORIGIN=http://localhost:8081

# Generate: openssl rand -hex 32 (TOKEN_ENCRYPTION_KEY must be 64 hex characters)
SESSION_SECRET=change-me-to-32-char-minimum-secret!!
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional — first-time setup draft write from automation/CLI (browser first write needs no header)
# Generate: openssl rand -hex 32
SETUP_BOOTSTRAP_SECRET=

API_PORT=3001
API_URL=http://127.0.0.1:3001
WEB_URL=http://localhost:3000

# Optional — defaults work for local dev (web proxies /api/v1 to API_URL)
# NEXT_PUBLIC_WS_URL=ws://localhost:3001

PCO_ORGANIZATION_ID=
ORGANIZATION_NAME=My Church
UPLOAD_DIR=./uploads
PUBLIC_UPLOAD_URL=http://localhost:3000/api/uploads
